# STRC Intelligence Platform — Environment Variables

# Neon PostgreSQL
DATABASE_URL=postgresql://user:pass@host/strc-dashboard?sslmode=require

# Financial Modeling Prep
FMP_API_KEY=your_fmp_key

# FRED (Federal Reserve Economic Data)
FRED_API_KEY=your_fred_key

# Cron authentication
CRON_SECRET=your_cron_secret

# Tradier (MSTR options — real-time)
# Free sandbox: https://developer.tradier.com → create app → get sandbox token
TRADIER_API_KEY=your_tradier_token
# Set to 'true' for sandbox, remove or set 'false' for production
TRADIER_SANDBOX=true

# Optional: CoinGecko API key (free tier works without)
# COINGECKO_API_KEY=
